generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LibraryRootKind {
  EBOOKS
  AUDIOBOOKS
  MIXED
}

enum ScanMode {
  FULL
  INCREMENTAL
}

enum MediaKind {
  EPUB
  PDF
  CBZ
  AUDIO
  COVER
  SIDECAR
  OTHER
}

enum AvailabilityStatus {
  PRESENT
  MISSING
  IGNORED
}

enum FormatFamily {
  EBOOK
  AUDIOBOOK
}

enum ContributorRole {
  AUTHOR
  NARRATOR
  EDITOR
  TRANSLATOR
  ILLUSTRATOR
  OTHER
}

enum EditionFileRole {
  PRIMARY
  ALTERNATE_FORMAT
  SUPPLEMENT
  AUDIO_TRACK
}

enum CollectionKind {
  MANUAL
}

enum ShelfFormatFilter {
  ALL
  EBOOK
  AUDIOBOOK
}

enum ProgressKind {
  EBOOK
  AUDIO
  READALOUD
}

enum ProgressTrackingMode {
  BY_EDITION
  BY_WORK
}

enum DuplicateReason {
  SAME_HASH
  SAME_ISBN
  SIMILAR_TITLE_AUTHOR
  SAME_PATH_PATTERN
}

enum ReviewStatus {
  PENDING
  IGNORED
  CONFIRMED
  MERGED
}

enum MatchSuggestionType {
  SAME_WORK
  EXACT_METADATA
  NORMALIZED_TITLE
  SUBTITLE_STRIPPED
  TITLE_ONLY
}

enum EnrichmentStatus {
  STUB
  ENRICHED
}

enum KoboDeviceStatus {
  ACTIVE
  REVOKED
}

enum ImportJobKind {
  SCAN_ROOT
  HASH_FILE
  PARSE_FILE
  REFRESH_METADATA
  DETECT_DUPLICATES
  MATCH_SUGGESTIONS
  ENRICH_AUTHOR_PHOTOS
}

enum ImportJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum ScanStage {
  DISCOVERY
  PROCESSING
}

model User {
  id              String            @id @default(cuid())
  email           String?           @unique
  name            String?
  image           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  identities      UserIdentity[]
  preferences     UserPreference?
  roles           UserRole[]
  collections     Collection[]
  readingProgress ReadingProgress[]
  workProgressPreferences WorkProgressPreference[]
  koboDevices     KoboDevice[]
}

model UserIdentity {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  metadata          Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  role   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model LibraryRoot {
  id            String            @id @default(cuid())
  name          String
  path          String            @unique
  kind          LibraryRootKind
  scanMode      ScanMode          @default(INCREMENTAL)
  isEnabled     Boolean           @default(true)
  lastScannedAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  fileAssets FileAsset[]
  importJobs ImportJob[]
}

model FileAsset {
  id                 String             @id @default(cuid())
  libraryRootId      String
  absolutePath       String             @unique
  relativePath       String
  basename           String
  extension          String?
  mimeType           String?
  sizeBytes          BigInt?
  ctime              DateTime?
  mtime              DateTime?
  partialHash        String?
  fullHash           String?
  metadata           Json?
  mediaKind          MediaKind
  availabilityStatus AvailabilityStatus @default(PRESENT)
  lastSeenAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  libraryRoot LibraryRoot @relation(fields: [libraryRootId], references: [id], onDelete: Cascade)
  editionFiles EditionFile[]

  duplicateLeft  DuplicateCandidate[] @relation("DuplicateLeftFile")
  duplicateRight DuplicateCandidate[] @relation("DuplicateRightFile")

  @@index([libraryRootId])
  @@index([libraryRootId, availabilityStatus])
  @@index([partialHash])
  @@index([fullHash])
}

model Work {
  id             String   @id @default(cuid())
  titleCanonical String
  titleDisplay   String
  sortTitle      String?
  description    String?
  coverPath      String?
  coverColors    Json?
  seriesId         String?
  seriesPosition   Float?
  enrichmentStatus EnrichmentStatus @default(ENRICHED)
  editedFields     String[]         @default([])
  createdAt        DateTime         @default(now())
  updatedAt      DateTime @updatedAt

  series   Series?   @relation(fields: [seriesId], references: [id])
  editions Edition[]
  progressPreferences WorkProgressPreference[]

  tags WorkTag[]

  targetMatchSuggestions    MatchSuggestion[] @relation("TargetWork")
  suggestedMatchSuggestions MatchSuggestion[] @relation("SuggestedWork")
  externalLinks             ExternalLink[]

  @@index([titleCanonical])
}

model Edition {
  id           String       @id @default(cuid())
  workId       String
  formatFamily FormatFamily
  publisher    String?
  publishedAt  DateTime?
  isbn13       String?
  isbn10       String?
  asin         String?
  language     String?
  pageCount    Int?
  editedFields String[]     @default([])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  work            Work                 @relation(fields: [workId], references: [id], onDelete: Cascade)
  editionFiles    EditionFile[]
  contributors    EditionContributor[]
  readingProgress ReadingProgress[]
  externalLinks   ExternalLink[]
  collectionItems CollectionItem[]
  koboSyncedBooks KoboSyncedBook[]

  duplicateLeft  DuplicateCandidate[] @relation("DuplicateLeftEdition")
  duplicateRight DuplicateCandidate[] @relation("DuplicateRightEdition")

  @@index([workId])
  @@index([isbn13])
  @@index([isbn10])
  @@index([asin])
  @@index([formatFamily])
  @@index([publisher])
}

model EditionFile {
  id          String          @id @default(cuid())
  editionId   String
  fileAssetId String
  role        EditionFileRole @default(PRIMARY)

  edition   Edition   @relation(fields: [editionId], references: [id], onDelete: Cascade)
  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@unique([editionId, fileAssetId])
}

model Contributor {
  id            String   @id @default(cuid())
  nameDisplay   String
  nameCanonical String
  imagePath     String?
  createdAt     DateTime @default(now())

  editions EditionContributor[]

  @@index([nameCanonical])
}

model EditionContributor {
  id            String          @id @default(cuid())
  editionId     String
  contributorId String
  role          ContributorRole

  edition     Edition     @relation(fields: [editionId], references: [id], onDelete: Cascade)
  contributor Contributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)

  @@unique([editionId, contributorId, role])
}

model Series {
  id   String @id @default(cuid())
  name String

  works Work[]

  @@index([name])
}

model Collection {
  id           String            @id @default(cuid())
  ownerUserId  String?
  name         String
  kind         CollectionKind    @default(MANUAL)
  formatFilter ShelfFormatFilter @default(ALL)

  ownerUser             User?                  @relation(fields: [ownerUserId], references: [id])
  items                 CollectionItem[]
  koboDeviceCollections KoboDeviceCollection[]
}

model CollectionItem {
  id           String @id @default(cuid())
  collectionId String
  editionId    String

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  edition    Edition    @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, editionId])
}

model ReadingProgress {
  id           String       @id @default(cuid())
  userId       String
  editionId    String
  progressKind ProgressKind
  locator      Json
  percent      Float?
  source       String?
  updatedAt    DateTime     @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  edition Edition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@index([userId, editionId])
}

model UserPreference {
  id                   String               @id @default(cuid())
  userId               String               @unique
  progressTrackingMode ProgressTrackingMode @default(BY_EDITION)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkProgressPreference {
  id                   String               @id @default(cuid())
  userId               String
  workId               String
  progressTrackingMode ProgressTrackingMode

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([workId])
}

model MatchSuggestion {
  id              String              @id @default(cuid())
  targetWorkId    String
  suggestedWorkId String
  matchType       MatchSuggestionType
  confidence      Float?
  reviewStatus    ReviewStatus        @default(PENDING)

  targetWork    Work @relation("TargetWork", fields: [targetWorkId], references: [id], onDelete: Cascade)
  suggestedWork Work @relation("SuggestedWork", fields: [suggestedWorkId], references: [id], onDelete: Cascade)

  @@unique([targetWorkId, suggestedWorkId])
}

model ExternalLink {
  id            String   @id @default(cuid())
  editionId     String?
  workId        String?
  provider      String
  externalId    String
  metadata      Json?
  lastSyncedAt  DateTime?
  appliedAt     DateTime?
  appliedFields String[] @default([])

  edition Edition? @relation(fields: [editionId], references: [id], onDelete: Cascade)
  work    Work?    @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([editionId, provider, externalId])
  @@unique([workId, provider, externalId])
  @@index([workId])
}

model DuplicateCandidate {
  id               String          @id @default(cuid())
  leftEditionId    String?
  rightEditionId   String?
  leftFileAssetId  String?
  rightFileAssetId String?
  reason           DuplicateReason
  confidence       Float?
  status           ReviewStatus    @default(PENDING)

  leftEdition    Edition?  @relation("DuplicateLeftEdition", fields: [leftEditionId], references: [id])
  rightEdition   Edition?  @relation("DuplicateRightEdition", fields: [rightEditionId], references: [id])
  leftFileAsset  FileAsset? @relation("DuplicateLeftFile", fields: [leftFileAssetId], references: [id])
  rightFileAsset FileAsset? @relation("DuplicateRightFile", fields: [rightFileAssetId], references: [id])
}

model ImportJob {
  id             String          @id @default(cuid())
  bullmqJobId    String?         @unique
  libraryRootId  String?
  kind           ImportJobKind
  status         ImportJobStatus @default(QUEUED)
  payload        Json?
  error          String?
  attemptsMade   Int             @default(0)
  totalFiles             Int?
  processedFiles         Int?
  errorCount             Int?
  scanStage              ScanStage?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  startedAt      DateTime?
  finishedAt     DateTime?

  libraryRoot LibraryRoot? @relation(fields: [libraryRootId], references: [id])

  @@index([status])
  @@index([libraryRootId, status])
  @@index([kind])
  @@index([createdAt])
}

model AppSetting {
  key   String @id
  value String
}

model Tag {
  id            String    @id @default(cuid())
  name          String    @unique
  nameCanonical String    @unique
  createdAt     DateTime  @default(now())

  works WorkTag[]

  @@index([nameCanonical])
}

model WorkTag {
  id     String @id @default(cuid())
  workId String
  tagId  String

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([workId, tagId])
}

model KoboDevice {
  id         String           @id @default(cuid())
  userId     String
  deviceId   String
  userKey    String
  authToken  String           @unique
  status     KoboDeviceStatus @default(ACTIVE)
  lastSyncAt DateTime?
  createdAt  DateTime         @default(now())

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  collections KoboDeviceCollection[]
  syncedBooks KoboSyncedBook[]

  @@unique([userId, deviceId])
}

model KoboDeviceCollection {
  id           String @id @default(cuid())
  koboDeviceId String
  collectionId String

  device     KoboDevice @relation(fields: [koboDeviceId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([koboDeviceId, collectionId])
}

model KoboSyncedBook {
  id           String    @id @default(cuid())
  koboDeviceId String
  editionId    String
  syncedAt     DateTime  @default(now())
  removedAt    DateTime?

  device  KoboDevice @relation(fields: [koboDeviceId], references: [id], onDelete: Cascade)
  edition Edition    @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@unique([koboDeviceId, editionId])
  @@index([koboDeviceId])
}
