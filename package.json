{
  "name": "bookhouse",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @bookhouse/db generate",
    "db:migrate": "pnpm --filter @bookhouse/db migrate",
    "db:push": "pnpm --filter @bookhouse/db push",
    "db:studio": "pnpm --filter @bookhouse/db studio",
    "queue:test": "pnpm --filter @bookhouse/library-worker enqueue-test",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache .output"
  }
}
