# Database
DATABASE_URL=postgresql://bookhouse:bookhouse@localhost:5432/bookhouse

# Valkey (Redis-compatible)
QUEUE_URL=redis://localhost:6379

# Auth (OIDC)
AUTH_SECRET=change-me-in-production
AUTH_OIDC_ISSUER=https://your-oidc-provider.example.com
AUTH_OIDC_CLIENT_ID=bookhouse
AUTH_OIDC_CLIENT_SECRET=change-me

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Backup (optional — set if pg_dump/psql are not in PATH, e.g. in Docker-based dev environments)
# PG_DUMP_PATH=/usr/lib/postgresql/17/bin/pg_dump
# PSQL_PATH=/usr/lib/postgresql/17/bin/psql
